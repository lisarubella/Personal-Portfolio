# This file is for local development only
# Copy this to .env.local and update with your values
# NEVER commit .env.local to Git

# API Configuration (if needed for future features)
# NEXT_PUBLIC_API_URL=https://api.example.com

# Email Configuration (optional)
# CONTACT_EMAIL=mona@example.com

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Note: Variables starting with NEXT_PUBLIC_ are exposed to browser
# Variables without NEXT_PUBLIC_ are server-only and secure
